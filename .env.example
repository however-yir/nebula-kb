# NebulaKB environment template (preferred prefix: NEBULA_)
# LZKB_ and MAXKB_ keys are still supported for compatibility.

NEBULA_CONFIG_TYPE=ENV
APP_ENV=dev
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
TOKEN_EXPIRE=900
NEBULA_LOG_LEVEL=INFO

# Canonical service contracts
DATABASE_URL=postgresql://root:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/nebula
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379/0
STORAGE_BACKEND=local
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=
STORAGE_HEALTHCHECK_URL=

# Database compatibility keys
NEBULA_DB_NAME=nebula
NEBULA_DB_HOST=127.0.0.1
NEBULA_DB_PORT=5432
NEBULA_DB_USER=root
NEBULA_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
NEBULA_DB_MAX_OVERFLOW=80
LZKB_DB_NAME=nebula
LZKB_DB_HOST=127.0.0.1
LZKB_DB_PORT=5432
LZKB_DB_USER=root
LZKB_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
LZKB_DB_MAX_OVERFLOW=80

# Redis
NEBULA_REDIS_HOST=127.0.0.1
NEBULA_REDIS_PORT=6379
NEBULA_REDIS_DB=0
NEBULA_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
NEBULA_REDIS_MAX_CONNECTIONS=100
LZKB_REDIS_HOST=127.0.0.1
LZKB_REDIS_PORT=6379
LZKB_REDIS_DB=0
LZKB_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
LZKB_REDIS_MAX_CONNECTIONS=100

# Local model service
NEBULA_LOCAL_MODEL_PROTOCOL=http
NEBULA_LOCAL_MODEL_HOST=127.0.0.1
NEBULA_LOCAL_MODEL_PORT=11636
NEBULA_LOCAL_MODEL_HOST_WORKER=1
NEBULA_MODEL_SERVICE_HEALTHCHECK_ENABLED=true
NEBULA_EMBEDDING_MODEL_PATH=/tmp/nebula/model/embedding
NEBULA_EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese
LZKB_LOCAL_MODEL_PROTOCOL=http
LZKB_LOCAL_MODEL_HOST=127.0.0.1
LZKB_LOCAL_MODEL_PORT=11636
LZKB_LOCAL_MODEL_HOST_WORKER=1
LZKB_MODEL_SERVICE_HEALTHCHECK_ENABLED=true
LZKB_EMBEDDING_MODEL_PATH=/tmp/nebula/model/embedding
LZKB_EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese
HF_HOME=/tmp/nebula/model/base
TMPDIR=/tmp/nebula/tmp
TIKTOKEN_CACHE_DIR=/tmp/nebula/model/tokenizer/openai-tiktoken-cl100k-base

# App behavior
NEBULA_LANGUAGE_CODE=zh-CN
NEBULA_TIME_ZONE=Asia/Shanghai
NEBULA_HTTP_LISTEN_PORT=8080
NEBULA_SCHEDULER_HTTP_PORT=6060
NEBULA_ADMIN_PATH=/admin
NEBULA_CHAT_PATH=/chat
NEBULA_DEFAULT_PASSWORD=ChangeMe@1234!
LZKB_LANGUAGE_CODE=zh-CN
LZKB_TIME_ZONE=Asia/Shanghai
LZKB_HTTP_LISTEN_PORT=8080
LZKB_SCHEDULER_HTTP_PORT=6060
LZKB_ADMIN_PATH=/admin
LZKB_CHAT_PATH=/chat
LZKB_DEFAULT_PASSWORD=ChangeMe@1234!

# Brand & links
NEBULA_APP_NAME=NebulaKB
NEBULA_APPSTORE_URL=https://raw.githubusercontent.com/however-yir/nebula-kb/main/appstore/nebula.json
NEBULA_PROJECT_URL=https://github.com/however-yir/nebula-kb
NEBULA_HELP_URL=https://docs.nebulakb.ai
NEBULA_DOCS_URL=https://docs.nebulakb.ai
NEBULA_PRICING_URL=https://nebulakb.ai/pricing
NEBULA_CONTACT_URL=https://github.com/however-yir/nebula-kb/issues
NEBULA_OFFICIAL_SITE_URL=https://nebulakb.ai
NEBULA_CHAT_FLOAT_ICON=NebulaKB.gif

# Ollama
NEBULA_OLLAMA_BASE_URL=http://127.0.0.1:11434
LZKB_OLLAMA_BASE_URL=http://127.0.0.1:11434
