# LZKB environment template (preferred prefix: LZKB_)
# MAXKB_ keys are still supported for compatibility.

LZKB_CONFIG_TYPE=ENV
APP_ENV=dev
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY
TOKEN_EXPIRE=900
LZKB_LOG_LEVEL=INFO

# Canonical service contracts
DATABASE_URL=postgresql://root:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/lzkb
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379/0
STORAGE_BACKEND=local
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=
STORAGE_HEALTHCHECK_URL=

# Database compatibility keys
LZKB_DB_NAME=lzkb
LZKB_DB_HOST=127.0.0.1
LZKB_DB_PORT=5432
LZKB_DB_USER=root
LZKB_DB_PASSWORD=CHANGE_ME_DB_PASSWORD
LZKB_DB_MAX_OVERFLOW=80

# Redis
LZKB_REDIS_HOST=127.0.0.1
LZKB_REDIS_PORT=6379
LZKB_REDIS_DB=0
LZKB_REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
LZKB_REDIS_MAX_CONNECTIONS=100

# Local model service
LZKB_LOCAL_MODEL_PROTOCOL=http
LZKB_LOCAL_MODEL_HOST=127.0.0.1
LZKB_LOCAL_MODEL_PORT=11636
LZKB_LOCAL_MODEL_HOST_WORKER=1
LZKB_MODEL_SERVICE_HEALTHCHECK_ENABLED=true
LZKB_EMBEDDING_MODEL_PATH=/tmp/lzkb/model/embedding
LZKB_EMBEDDING_MODEL_NAME=shibing624/text2vec-base-chinese
HF_HOME=/tmp/lzkb/model/base
TMPDIR=/tmp/lzkb/tmp
TIKTOKEN_CACHE_DIR=/tmp/lzkb/model/tokenizer/openai-tiktoken-cl100k-base

# App behavior
LZKB_LANGUAGE_CODE=zh-CN
LZKB_TIME_ZONE=Asia/Shanghai
LZKB_HTTP_LISTEN_PORT=8080
LZKB_SCHEDULER_HTTP_PORT=6060
LZKB_ADMIN_PATH=/admin
LZKB_CHAT_PATH=/chat
LZKB_DEFAULT_PASSWORD=ChangeMe@1234!

# Brand & links
LZKB_APP_NAME=NebulaKB
LZKB_APPSTORE_URL=https://raw.githubusercontent.com/however-yir/LZKB/main/appstore/lzkb.json
LZKB_PROJECT_URL=https://github.com/however-yir/LZKB
LZKB_HELP_URL=https://github.com/however-yir/LZKB/wiki
LZKB_PRICING_URL=https://github.com/however-yir/LZKB#readme
LZKB_CONTACT_URL=https://github.com/however-yir/LZKB/issues
LZKB_OFFICIAL_SITE_URL=https://github.com/however-yir/LZKB
LZKB_CHAT_FLOAT_ICON=LZKB.gif

# Ollama
LZKB_OLLAMA_BASE_URL=http://127.0.0.1:11434
