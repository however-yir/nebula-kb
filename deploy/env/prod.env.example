LZKB_CONFIG_TYPE=ENV
APP_ENV=prod

# Prefer *_FILE when your platform supports Docker/Kubernetes secrets.
SECRET_KEY_FILE=/run/secrets/lzkb_secret_key
DATABASE_URL_FILE=/run/secrets/lzkb_database_url
REDIS_URL_FILE=/run/secrets/lzkb_redis_url
POSTGRES_DB=lzkb
POSTGRES_USER=lzkb
POSTGRES_PASSWORD=CHANGE_ME_INFRA_DB_PASSWORD
REDIS_PASSWORD=CHANGE_ME_INFRA_REDIS_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_INFRA_STORAGE_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_INFRA_STORAGE_SECRET_KEY

LZKB_LOG_LEVEL=INFO
LZKB_DEBUG=false
LZKB_HTTP_LISTEN_PORT=8080
LZKB_SCHEDULER_HTTP_PORT=6060
LZKB_LOCAL_MODEL_PROTOCOL=http
LZKB_LOCAL_MODEL_HOST=local-model
LZKB_LOCAL_MODEL_PORT=11636
LZKB_MODEL_SERVICE_HEALTHCHECK_ENABLED=true

STORAGE_BACKEND=s3
STORAGE_ENDPOINT=https://storage.example.com
STORAGE_BUCKET=lzkb
STORAGE_ACCESS_KEY_FILE=/run/secrets/lzkb_storage_access_key
STORAGE_SECRET_KEY_FILE=/run/secrets/lzkb_storage_secret_key
STORAGE_REGION=us-east-1
STORAGE_HEALTHCHECK_URL=
STORAGE_FORCE_PATH_STYLE=true
