NEBULA_CONFIG_TYPE=ENV
APP_ENV=prod

# Prefer *_FILE when your platform supports Docker/Kubernetes secrets.
SECRET_KEY_FILE=/run/secrets/nebula_secret_key
DATABASE_URL_FILE=/run/secrets/nebula_database_url
REDIS_URL_FILE=/run/secrets/nebula_redis_url
POSTGRES_DB=nebula
POSTGRES_USER=nebula
POSTGRES_PASSWORD=CHANGE_ME_INFRA_DB_PASSWORD
REDIS_PASSWORD=CHANGE_ME_INFRA_REDIS_PASSWORD
MINIO_ROOT_USER=CHANGE_ME_INFRA_STORAGE_ACCESS_KEY
MINIO_ROOT_PASSWORD=CHANGE_ME_INFRA_STORAGE_SECRET_KEY

NEBULA_LOG_LEVEL=INFO
NEBULA_DEBUG=false
NEBULA_HTTP_LISTEN_PORT=8080
NEBULA_SCHEDULER_HTTP_PORT=6060
NEBULA_LOCAL_MODEL_PROTOCOL=http
NEBULA_LOCAL_MODEL_HOST=local-model
NEBULA_LOCAL_MODEL_PORT=11636
NEBULA_MODEL_SERVICE_HEALTHCHECK_ENABLED=true

STORAGE_BACKEND=s3
STORAGE_ENDPOINT=https://storage.example.com
STORAGE_BUCKET=nebula
STORAGE_ACCESS_KEY_FILE=/run/secrets/nebula_storage_access_key
STORAGE_SECRET_KEY_FILE=/run/secrets/nebula_storage_secret_key
STORAGE_REGION=us-east-1
STORAGE_HEALTHCHECK_URL=
STORAGE_FORCE_PATH_STYLE=true
