NEBULA_CONFIG_TYPE=ENV
APP_ENV=dev
SECRET_KEY=dev-only-change-before-sharing
DATABASE_URL=postgresql://root:dev-db-password@postgres:5432/nebula
REDIS_URL=redis://:dev-redis-password@redis:6379/0
POSTGRES_DB=nebula
POSTGRES_USER=root
POSTGRES_PASSWORD=dev-db-password
REDIS_PASSWORD=dev-redis-password
MINIO_ROOT_USER=nebula-dev
MINIO_ROOT_PASSWORD=nebula-dev-secret

NEBULA_LOG_LEVEL=DEBUG
NEBULA_DEBUG=true
NEBULA_HTTP_LISTEN_PORT=8080
NEBULA_SCHEDULER_HTTP_PORT=6060
NEBULA_LOCAL_MODEL_PROTOCOL=http
NEBULA_LOCAL_MODEL_HOST=local-model
NEBULA_LOCAL_MODEL_PORT=11636
NEBULA_MODEL_SERVICE_HEALTHCHECK_ENABLED=true

STORAGE_BACKEND=s3
STORAGE_ENDPOINT=http://object-storage:9000
STORAGE_BUCKET=nebula
STORAGE_ACCESS_KEY=nebula-dev
STORAGE_SECRET_KEY=nebula-dev-secret
STORAGE_REGION=us-east-1
STORAGE_HEALTHCHECK_URL=http://object-storage:9000/minio/health/ready
STORAGE_FORCE_PATH_STYLE=true
