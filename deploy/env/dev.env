LZKB_CONFIG_TYPE=ENV
APP_ENV=dev
SECRET_KEY=dev-only-change-before-sharing
DATABASE_URL=postgresql://root:dev-db-password@postgres:5432/lzkb
REDIS_URL=redis://:dev-redis-password@redis:6379/0
POSTGRES_DB=lzkb
POSTGRES_USER=root
POSTGRES_PASSWORD=dev-db-password
REDIS_PASSWORD=dev-redis-password
MINIO_ROOT_USER=lzkb-dev
MINIO_ROOT_PASSWORD=lzkb-dev-secret

LZKB_LOG_LEVEL=DEBUG
LZKB_DEBUG=true
LZKB_HTTP_LISTEN_PORT=8080
LZKB_SCHEDULER_HTTP_PORT=6060
LZKB_LOCAL_MODEL_PROTOCOL=http
LZKB_LOCAL_MODEL_HOST=local-model
LZKB_LOCAL_MODEL_PORT=11636
LZKB_MODEL_SERVICE_HEALTHCHECK_ENABLED=true

STORAGE_BACKEND=s3
STORAGE_ENDPOINT=http://object-storage:9000
STORAGE_BUCKET=lzkb
STORAGE_ACCESS_KEY=lzkb-dev
STORAGE_SECRET_KEY=lzkb-dev-secret
STORAGE_REGION=us-east-1
STORAGE_HEALTHCHECK_URL=http://object-storage:9000/minio/health/ready
STORAGE_FORCE_PATH_STYLE=true
